# ==============================================================================
# iQuant 后端开发镜像
# 镜像只装依赖；源码通过 docker-compose 卷挂载进容器，运行时由 uvicorn --reload 热更新
# ==============================================================================
FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple \
    PATH="/workspace/.venv/bin:$PATH" \
    UV_LINK_MODE=copy

WORKDIR /workspace

# 开发期需要：构建工具 + libpq + git（pip install -e）+ 网络工具便于排障
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        gcc \
        libpq-dev \
        git \
        curl \
        ca-certificates \
        tzdata \
        netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && pip install uv==0.5.11

# 只复制依赖描述用于镜像层缓存；源码不进镜像
COPY pyproject.toml uv.lock* ./
COPY apps/api/pyproject.toml ./apps/api/
COPY apps/worker/pyproject.toml ./apps/worker/
COPY services/market-service/pyproject.toml ./services/market-service/
COPY packages/domain/pyproject.toml ./packages/domain/
COPY packages/market-data/pyproject.toml ./packages/market-data/

# 依赖解析（允许 lock 缺失：首次构建会现解算）
RUN uv sync --all-packages --group dev

EXPOSE 8000

# 容器启动后 compose 会用 command 覆盖。这里给出兜底，便于 docker run 调试。
CMD ["bash"]
