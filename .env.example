# ==============================================================================
# iQuant 环境变量样例 - 复制为 .env 后按需修改，.env 不入库
# ==============================================================================

# 运行环境：local / dev / staging / prod
IQUANT_ENV=local
TZ=Asia/Shanghai

# --- API ---------------------------------------------------------------------
IQUANT_API_HOST=0.0.0.0
IQUANT_API_PORT=8001
IQUANT_API_LOG_LEVEL=INFO
# 错误日志（容器内相对工作目录；logs/ 已 .gitignore；生产见 Compose logs 卷）
IQUANT_API_ERROR_LOG_PATH=logs/iquant-api-errors.log
IQUANT_CLIENT_ERROR_LOG_PATH=logs/iquant-admin-web-errors.log
IQUANT_WORKER_ERROR_LOG_PATH=logs/iquant-worker-errors.log

# 用于签发 JWT，生产环境必须改成强随机密钥
IQUANT_SECRET_KEY=please-change-me-in-production-with-a-long-random-string

# --- 业务主库 PostgreSQL ------------------------------------------------------
IQUANT_PG_HOST=postgres
IQUANT_PG_PORT=5432
IQUANT_PG_DB=iquant
IQUANT_PG_USER=iquant
IQUANT_PG_PASSWORD=iquant_dev_pwd
# SQLAlchemy 异步连接 DSN。宿主机直连本机端口时用 127.0.0.1；仅容器内可用服务名 postgres。
IQUANT_PG_DSN=postgresql+asyncpg://iquant:iquant_dev_pwd@postgres:5432/iquant

# --- 时序行情库 TimescaleDB ---------------------------------------------------
IQUANT_TS_HOST=timescaledb
IQUANT_TS_PORT=5432
IQUANT_TS_DB=iquant_market
IQUANT_TS_USER=iquant
IQUANT_TS_PASSWORD=iquant_dev_pwd
IQUANT_TS_DSN=postgresql+asyncpg://iquant:iquant_dev_pwd@timescaledb:5432/iquant_market

# --- Redis -------------------------------------------------------------------
# 主机名含义：redis 仅在 Docker Compose 网络内可解析。
# - API 跑在 compose 的 api/worker 容器里：可用 redis://redis:6379/0（compose 已对 api/worker 强制覆盖）。
# - API 跑在宿主机（IDE / uvicorn）：须改为 redis://127.0.0.1:6379/0，并先执行 compose up 让本机映射 6379。
IQUANT_REDIS_HOST=redis
IQUANT_REDIS_PORT=6379
IQUANT_REDIS_DB=0
IQUANT_REDIS_URL=redis://redis:6379/0

# --- Celery ------------------------------------------------------------------
IQUANT_CELERY_BROKER_URL=redis://redis:6379/1
IQUANT_CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- 通达信行情 ---------------------------------------------------------------
# 宿主机的通达信安装目录 vipdoc（包含 sh/sz/bj 子目录），将以只读形式挂载到容器
# Windows 示例：D:/通达信/vipdoc
# Linux/Mac 示例：/data/tdx/vipdoc
IQUANT_TDX_VIPDOC_HOST_DIR=C:/tdx/vipdoc

# 容器内可见的 vipdoc 路径（一般不需要改）
IQUANT_TDX_VIPDOC_DIR=/data/tdx/vipdoc

# TDX 在线请求并发与超时
IQUANT_TDX_POOL_SIZE=4
IQUANT_TDX_CONNECT_TIMEOUT=5
IQUANT_TDX_READ_TIMEOUT=10

# --- 管理员鉴权（identity-service）--------------------------------------------
# 签发管理员 JWT，生产必须改为强随机值
IQUANT_ADMIN_JWT_SECRET=please-change-me-admin-jwt-secret
IQUANT_ADMIN_ACCESS_TOKEN_MINUTES=15
IQUANT_ADMIN_REFRESH_TOKEN_DAYS=30

# 首个管理员 bootstrap（仅库内无管理员时使用一次）
IQUANT_ADMIN_BOOTSTRAP_USERNAME=admin
IQUANT_ADMIN_BOOTSTRAP_PASSWORD=change-me-8chars-min

# Cloudflare Turnstile（公网必填；本地留空则跳过校验）
IQUANT_TURNSTILE_SECRET=
IQUANT_TURNSTILE_SITE_KEY=

# 登录防暴力：每分钟次数 / 失败锁定阈值 / 锁定时长（秒）
IQUANT_LOGIN_RATE_LIMIT_PER_MINUTE=5
IQUANT_LOGIN_FAIL_LOCK_THRESHOLD=10
IQUANT_LOGIN_FAIL_LOCK_SECONDS=900

# 管理 API 限流（已登录 / 匿名）
IQUANT_ADMIN_API_RATE_LIMIT_PER_MINUTE=120
IQUANT_ANONYMOUS_ADMIN_RATE_LIMIT_PER_MINUTE=20

# SSE 进度 ticket 有效期（秒）
IQUANT_SSE_TICKET_SECONDS=60

# 生产 CORS：逗号分隔 Origin；开发可 *
IQUANT_CORS_ORIGINS=*
IQUANT_ADMIN_WEB_ORIGIN=http://localhost:5173

# 生产关闭 OpenAPI（local/dev 默认开启）
# IQUANT_OPENAPI_ENABLED=false

# --- Admin Web ----------------------------------------------------------------
IQUANT_ADMIN_WEB_PORT=5173

# 前端 npm 镜像（国内可改为 https://registry.npmmirror.com/，但稳定性较差时退回官方源）
IQUANT_NPM_REGISTRY=https://registry.npmjs.org/
# 前端开发服务器代理到 API（Compose 内 admin-web 已通过 VITE_API_PROXY 指向 api:8000）
IQUANT_ADMIN_API_BASE=http://api:8000

# 若在宿主机直接运行 admin-web（pnpm dev），请复制 apps/admin-web/.env.example → apps/admin-web/.env
# 并设置 VITE_API_PROXY=http://127.0.0.1:8001（与上方 IQUANT_API_PORT 映射一致）
